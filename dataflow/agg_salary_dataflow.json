{
	"name": "agg_salary_dataflow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DelimitedText11",
						"type": "DatasetReference"
					},
					"name": "empMissingSalary"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DelimitedText13",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          employee_id as string,",
				"          employee_code as string,",
				"          first_name as string,",
				"          last_name as string,",
				"          email as string,",
				"          department_id as string,",
				"          salary as string,",
				"          hire_date as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> empMissingSalary",
				"empMissingSalary aggregate(groupBy(hire_year = case(year(toDate(hire_date)) == 2020, '2020', \r",
				"    case(year(toDate(hire_date)) == 2021, '2021',\r",
				"        case(year(toDate(hire_date)) == 2022, '2022','2022 onwards'\r",
				"  )  \r",
				"    )\r",
				"\r",
				")),",
				"     num_emp = countDistinct(employee_id),",
				"          max_salary = max(salary),",
				"          avg_salary = avg(toInteger(salary)) ) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          employee_id as string,",
				"          employee_code as string,",
				"          first_name as string,",
				"          last_name as string,",
				"          email as string,",
				"          salary as string,",
				"          hire_date as string,",
				"          department_id as string,",
				"          department_name as string,",
				"          location as string",
				"     ),",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}