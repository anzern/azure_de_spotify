{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "spotifydatafactory223"
		},
		"AzureSqlDbspotify_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDbspotify'"
		},
		"spotifydatalake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'spotifydatalake'"
		},
		"AzureSqlDbspotify_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "spotifysqlserver223.database.windows.net"
		},
		"AzureSqlDbspotify_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "spotifydb"
		},
		"AzureSqlDbspotify_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "anzer_admin"
		},
		"spotifydatalake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://spotifydatalake223.dfs.core.windows.net/"
		},
		"storage_based_trigger_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/2d963abe-cc86-44ea-9f99-240014bd4607/resourceGroups/spotifyrg/providers/Microsoft.Storage/storageAccounts/spotifydatalake223"
		},
		"tumb_window_properties_pipeline_parameters_startdate": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowStartTime"
		},
		"tumb_window_properties_pipeline_parameters_enddate": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowEndTime"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "spotifydatafactory223_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureSqlDbspotify_password": {
						"value": "[parameters('AzureSqlDbspotify_password')]"
					},
					"spotifydatalake_accountKey": {
						"value": "[parameters('spotifydatalake_accountKey')]"
					},
					"AzureSqlDbspotify_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDbspotify_properties_typeProperties_server')]"
					},
					"AzureSqlDbspotify_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDbspotify_properties_typeProperties_database')]"
					},
					"AzureSqlDbspotify_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDbspotify_properties_typeProperties_userName')]"
					},
					"spotifydatalake_properties_typeProperties_url": {
						"value": "[parameters('spotifydatalake_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "spotifydatafactory223_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"storage_based_trigger_properties_typeProperties_scope": {
						"value": "[parameters('storage_based_trigger_properties_typeProperties_scope')]"
					},
					"tumb_window_properties_pipeline_parameters_startdate": {
						"value": "[parameters('tumb_window_properties_pipeline_parameters_startdate')]"
					},
					"tumb_window_properties_pipeline_parameters_enddate": {
						"value": "[parameters('tumb_window_properties_pipeline_parameters_enddate')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'spotifydatafactory223_ArmTemplate_0')]"
			]
		}
	]
}